CATEGORIES = {
    "1": ("1xx", "Informational", "\033[96m"),  # cyan
    "2": ("2xx", "Success", "\033[92m"),         # green
    "3": ("3xx", "Redirection", "\033[93m"),     # yellow
    "4": ("4xx", "Client Error", "\033[91m"),    # red
    "5": ("5xx", "Server Error", "\033[95m"),    # magenta
}

RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"

_use_color = hasattr(sys.stdout, 'isatty') and sys.stdout.isatty()


def c(text, *codes):
    """Apply ANSI color codes to text, only if stdout is a terminal."""
    if _use_color and codes:
        return f"{''.join(codes)}{text}{RESET}"
    return text


def print_code(code):
    name = STATUS_CODES.get(code)
    if not name:
        print(f"Unknown status code: {code}")
        return False

    cat = CATEGORIES.get(code[0], ("???", "Unknown", ""))
    cat_color = cat[2]

    print()
    print(f"  {c(code, BOLD, cat_color)}  {c(name, cat_color)}")
    print(f"  {c(f'{cat[0]} {cat[1]}', DIM)}")
    print()

    desc = DESCRIPTIONS.get(code)
    if desc:
        # Word wrap to ~70 chars with indent
        words = desc.split()
        line = "  "
        for word in words:
            if len(line) + len(word) + 1 > 72:
                print(line)
                line = "  " + word
            else:
                line += (" " if len(line) > 2 else "") + word
        if line.strip():
            print(line)
        print()

    return True


def print_category(cat_prefix):
    cat = CATEGORIES.get(cat_prefix)
    if not cat:
        print(f"Unknown category: {cat_prefix}xx")
        return

    print()
    print(f"  {c(cat[0] + ' ' + cat[1], BOLD, cat[2])}")
    print(f"  {c('─' * 40, DIM)}")

    for code in sorted(STATUS_CODES.keys(), key=int):
        if code[0] == cat_prefix:
            name = STATUS_CODES[code]
            print(f"  {c(code, cat[2])}  {name}")
    print()


def print_all():
    for cat_prefix in "12345":
        print_category(cat_prefix)


def print_search(query):
    query = query.lower()
    matches = []
    for code, name in sorted(STATUS_CODES.items(), key=lambda x: int(x[0])):
        desc = DESCRIPTIONS.get(code, "")
        if query in code or query in name.lower() or query in desc.lower():
            matches.append(code)

    if not matches:
        print(f"  No status codes matching '{query}'")
        return

    print()
    for code in matches:
        cat = CATEGORIES.get(code[0], ("", "", ""))
        print(f"  {c(code, cat[2])}  {STATUS_CODES[code]}")
    print()
    print(f"  {c(f'{len(matches)} result(s)', DIM)}")
    print()


def print_usage():
    print()
    green = '\033[92m'
    print(f"  {c('httpparrot', BOLD, green)} - HTTP status code reference")
    print()
    print(f"  {c('Usage:', BOLD)}")
    print(f"    httpparrot {c('404', DIM)}          Look up a status code")
    print(f"    httpparrot {c('4xx', DIM)}          List a category")
    print(f"    httpparrot {c('all', DIM)}          List all codes")
    print(f"    httpparrot {c('search term', DIM)}  Search codes by keyword")
    print()
    print(f"  {c('Examples:', BOLD)}")
    print(f"    httpparrot 301")
    print(f"    httpparrot 5xx")
    print(f"    httpparrot teapot")
    print(f"    httpparrot 'not found'")
    print()


def main():
    if len(sys.argv) < 2:
        print_usage()
        return

    arg = sys.argv[1]

    # Direct code lookup
    if arg in STATUS_CODES:
        print_code(arg)
        return

    # Category: 1xx, 2xx, etc.
    if len(arg) == 3 and arg[0] in "12345" and arg[1:] == "xx":
        print_category(arg[0])
        return

    # List all
    if arg == "all":
        print_all()
        return

    # Try as a number (might be a valid but unlisted code)
    if arg.isdigit() and 100 <= int(arg) <= 599:
        if not print_code(arg):
            sys.exit(1)
        return

    # Search
    query = " ".join(sys.argv[1:])
    print_search(query)


if __name__ == "__main__":
    main()
